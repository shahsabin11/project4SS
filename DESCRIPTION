RoxygenNote: 8.0.0
Imports:
    checkmate,
    dplyr
Depends:
    R (>= 3.5)
LazyData: true
Suggests:
    knitr,
    rmarkdown,
    testthat (>= 3.0.0)
VignetteBuilder: knitr
